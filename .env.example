TASTYTRADE_CLIENT_SECRET=replace_me
TASTYTRADE_REFRESH_TOKEN=replace_me

# Local development defaults
DB_URL=sqlite:///spx_options.db
UNDERLYING_SYMBOL=SPX
OPTION_EXPIRIES_PER_RUN=2
OPTION_STRIKES_COUNT=140
OPTIONS_STREAM_TIMEOUT_SECONDS=20
COLLECTOR_LOG_LEVEL=INFO
COLLECTOR_DEBUG_EVENTS=false
COLLECTOR_DEBUG_SAMPLE_EVENTS=3

# Optional site tracking
TRACKING_DB_URL=sqlite:///site_tracking.db
TRACKING_ENABLED=false
TRACKING_METRICS_ENABLED=true
